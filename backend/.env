FOOTBALL_DATA_API_TOKEN=your_token_here
FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taticboard
# Limit requests: minimum 7 seconds delay between API calls to stay under 10 requests/minute (60s / 10 = 6s)
API_REQUEST_DELAY_SECONDS=7
SYNC_INTERVAL_HOURS=6